<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.mastereventos.controller.AdminDashboardController"
      prefHeight="600.0" prefWidth="900.0"
      style="-fx-background-color: #eef2ff;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Panel de Administrador"
           style="-fx-font-size: 30px; -fx-font-weight: bold;"/>

    <Label text="Gestion de eventos"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <ListView fx:id="eventosAdminListView"
              prefWidth="650"
              prefHeight="280"/>

    <Label text="Detalle del evento"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextArea fx:id="detalleEventoAdminArea"
              prefWidth="650"
              prefHeight="150"
              editable="false"
              wrapText="true"/>

</VBox>
