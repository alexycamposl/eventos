<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.mastereventos.controller.AdminDashboardController"
      prefWidth="1000.0" prefHeight="700.0"
      style="-fx-background-color: #eceff1;">

    <!-- ENCABEZADO -->
    <HBox alignment="CENTER_LEFT" spacing="20"
          style="-fx-background-color: #1565c0; -fx-padding: 12 20 12 20;">
        <Label text="MasterEventos — Panel Administrador"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Button text="Cerrar sesion" onAction="#handleLogout"
                style="-fx-background-color: #ef5350; -fx-text-fill: white;"/>
    </HBox>

    <!-- TAB PANE -->
    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- ══ TAB USUARIOS ══════════════════════════════════════════════════ -->
        <Tab text="Usuarios">
            <ScrollPane fitToWidth="true">
                <HBox spacing="20" style="-fx-padding: 15;">
                    <VBox spacing="8" prefWidth="380">
                        <Label text="Lista de usuarios" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <ListView fx:id="usuariosListView" prefHeight="380"/>
                        <HBox spacing="8">
                            <Button text="Nuevo" onAction="#handleNuevoUsuario"
                                    style="-fx-background-color: #2196f3; -fx-text-fill: white;"/>
                            <Button text="Eliminar" onAction="#handleEliminarUsuario"
                                    style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="10" prefWidth="380">
                        <Label text="Datos del usuario" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <Label text="ID:"/>
                        <TextField fx:id="uIdField" promptText="ID Usuario" editable="false"/>
                        <Label text="Nombre:"/>
                        <TextField fx:id="uNombreField" promptText="Nombre completo"/>
                        <Label text="Correo:"/>
                        <TextField fx:id="uCorreoField" promptText="correo@ejemplo.com"/>
                        <Label text="Telefono:"/>
                        <TextField fx:id="uTelefonoField" promptText="Telefono"/>
                        <Label text="Contrasena:"/>
                        <TextField fx:id="uPasswordField" promptText="Contrasena"/>
                        <Label text="Rol:"/>
                        <ComboBox fx:id="uRolComboBox" prefWidth="200"/>
                        <Button text="Guardar usuario" onAction="#handleGuardarUsuario"
                                style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-pref-width: 200;"/>
                    </VBox>
                </HBox>
            </ScrollPane>
        </Tab>

        <!-- ══ TAB EVENTOS ═══════════════════════════════════════════════════ -->
        <Tab text="Eventos">
            <ScrollPane fitToWidth="true">
                <VBox spacing="12" style="-fx-padding: 15;">
                    <HBox spacing="20">
                        <VBox spacing="8" prefWidth="380">
                            <Label text="Lista de eventos" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <ListView fx:id="eventosAdminListView" prefHeight="300"/>
                            <HBox spacing="6" alignment="CENTER">
                                <Button text="Nuevo" onAction="#handleNuevoEvento"
                                        style="-fx-background-color: #2196f3; -fx-text-fill: white;"/>
                                <Button text="Eliminar" onAction="#handleEliminarEvento"
                                        style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                            </HBox>
                            <Label text="Cambiar estado:" style="-fx-font-weight: bold;"/>
                            <HBox spacing="6">
                                <Button text="Publicar" onAction="#handlePublicarEvento"
                                        style="-fx-background-color: #4caf50; -fx-text-fill: white;"/>
                                <Button text="Pausar" onAction="#handlePausarEvento"
                                        style="-fx-background-color: #ff9800; -fx-text-fill: white;"/>
                                <Button text="Cancelar" onAction="#handleCancelarEvento"
                                        style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                                <Button text="Finalizar" onAction="#handleFinalizarEvento"
                                        style="-fx-background-color: #607d8b; -fx-text-fill: white;"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="8" prefWidth="380">
                            <Label text="Datos del evento" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                            <Label text="ID:"/>
                            <TextField fx:id="eIdField" promptText="ID Evento" editable="false"/>
                            <Label text="Nombre:"/>
                            <TextField fx:id="eNombreField" promptText="Nombre del evento"/>
                            <Label text="Categoria:"/>
                            <TextField fx:id="eCategoriaField" promptText="Concierto / Teatro / Conferencia"/>
                            <Label text="Ciudad:"/>
                            <TextField fx:id="eCiudadField" promptText="Ciudad"/>
                            <Label text="Fecha (YYYY-MM-DD HH:mm):"/>
                            <TextField fx:id="eFechaField" promptText="2026-06-15 20:00"/>
                            <Label text="Recinto:"/>
                            <TextField fx:id="eRecintoField" promptText="Nombre del recinto"/>
                            <Label text="Aforo:"/>
                            <TextField fx:id="eAforoField" promptText="0"/>
                            <Label text="Descripcion:"/>
                            <TextArea fx:id="eDescripcionArea" prefHeight="60" wrapText="true"/>
                            <Label text="Estado:"/>
                            <ComboBox fx:id="eEstadoComboBox" prefWidth="200"/>
                            <Button text="Guardar evento" onAction="#handleGuardarEvento"
                                    style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-pref-width: 200;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>
        </Tab>

        <!-- ══ TAB RECINTOS Y ZONAS ══════════════════════════════════════════ -->
        <Tab text="Recintos y Zonas">
            <ScrollPane fitToWidth="true">
                <HBox spacing="20" style="-fx-padding: 15;">
                    <VBox spacing="8" prefWidth="380">
                        <Label text="Evento:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="eventoZonaComboBox" prefWidth="350"
                                  promptText="Selecciona evento"/>
                        <Label text="Zonas del evento" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <ListView fx:id="zonasListView" prefHeight="320"/>
                        <HBox spacing="8">
                            <Button text="Nueva zona" onAction="#handleNuevaZona"
                                    style="-fx-background-color: #2196f3; -fx-text-fill: white;"/>
                            <Button text="Eliminar zona" onAction="#handleEliminarZona"
                                    style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="10" prefWidth="340">
                        <Label text="Datos de la zona" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <Label text="ID:"/>
                        <TextField fx:id="zIdField" promptText="ID Zona" editable="false"/>
                        <Label text="Nombre:"/>
                        <TextField fx:id="zNombreField" promptText="VIP / General / Preferencial"/>
                        <Label text="Capacidad:"/>
                        <TextField fx:id="zCapacidadField" promptText="100"/>
                        <Label text="Precio base ($):"/>
                        <TextField fx:id="zPrecioField" promptText="0"/>
                        <Button text="Guardar zona" onAction="#handleGuardarZona"
                                style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-pref-width: 200;"/>
                    </VBox>
                </HBox>
            </ScrollPane>
        </Tab>

        <!-- ══ TAB ASIENTOS ══════════════════════════════════════════════════ -->
        <Tab text="Asientos">
            <VBox spacing="12" style="-fx-padding: 15;">
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Evento:" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="eventoAsientoComboBox" prefWidth="300" promptText="Selecciona evento"/>
                    <Label text="Zona:" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="zonaAsientoComboBox" prefWidth="200" promptText="Selecciona zona"/>
                </HBox>
                <ListView fx:id="asientosListView" prefHeight="380"/>
                <HBox spacing="10">
                    <Button text="Habilitar (Disponible)" onAction="#handleHabilitarAsiento"
                            style="-fx-background-color: #4caf50; -fx-text-fill: white;"/>
                    <Button text="Bloquear" onAction="#handleBloquearAsiento"
                            style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                    <Button text="Liberar" onAction="#handleLiberarAsiento"
                            style="-fx-background-color: #ff9800; -fx-text-fill: white;"/>
                    <Button text="Agregar asiento" onAction="#handleAgregarAsiento"
                            style="-fx-background-color: #2196f3; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- ══ TAB COMPRAS ═══════════════════════════════════════════════════ -->
        <Tab text="Compras">
            <HBox spacing="20" style="-fx-padding: 15;">
                <VBox spacing="8" prefWidth="500">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Estado:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="compraEstadoFiltro" prefWidth="160"/>
                        <Button text="Filtrar" onAction="#handleFiltrarCompras"/>
                        <Button text="Actualizar" onAction="#handleActualizarCompras"/>
                    </HBox>
                    <ListView fx:id="comprasListView" prefHeight="360"/>
                    <HBox spacing="8">
                        <Button text="Cancelar compra" onAction="#handleCancelarCompraAdmin"
                                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                        <Button text="Reembolsar" onAction="#handleReembolsarCompra"
                                style="-fx-background-color: #ff9800; -fx-text-fill: white;"/>
                        <Button text="Confirmar" onAction="#handleConfirmarCompraAdmin"
                                style="-fx-background-color: #4caf50; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
                <VBox spacing="8" prefWidth="360">
                    <Label text="Detalle de compra" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <TextArea fx:id="detalleCompraArea" prefHeight="420" editable="false" wrapText="true"/>
                </VBox>
            </HBox>
        </Tab>

        <!-- ══ TAB INCIDENCIAS ═══════════════════════════════════════════════ -->
        <Tab text="Incidencias">
            <HBox spacing="20" style="-fx-padding: 15;">
                <VBox spacing="8" prefWidth="420">
                    <HBox spacing="10">
                        <Label text="Filtrar por tipo:" style="-fx-font-weight: bold;"/>
                        <ComboBox fx:id="filtroTipoIncidencia" prefWidth="200"/>
                        <Button text="Filtrar" onAction="#handleFiltrarIncidencias"/>
                    </HBox>
                    <ListView fx:id="incidenciasListView" prefHeight="380"/>
                </VBox>
                <VBox spacing="10" prefWidth="380">
                    <Label text="Registrar incidencia" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label text="Tipo:"/>
                    <ComboBox fx:id="tipoIncidenciaComboBox" prefWidth="320"/>
                    <Label text="Entidad afectada (ID compra/evento/usuario):"/>
                    <TextField fx:id="incidenciaEntidadField" promptText="ID de la entidad afectada"/>
                    <Label text="Descripcion:"/>
                    <TextArea fx:id="incidenciaDescripcionArea" prefHeight="120" wrapText="true"
                              promptText="Describe la incidencia..."/>
                    <Button text="Registrar incidencia" onAction="#handleRegistrarIncidencia"
                            style="-fx-background-color: #9c27b0; -fx-text-fill: white; -fx-pref-width: 200;"/>
                </VBox>
            </HBox>
        </Tab>

        <!-- ══ TAB MÉTRICAS ══════════════════════════════════════════════════ -->
        <Tab text="Metricas y Reportes">
            <ScrollPane fitToWidth="true">
                <VBox spacing="15" style="-fx-padding: 15;">

                    <!-- Resumen KPIs -->
                    <HBox spacing="30" alignment="CENTER">
                        <VBox alignment="CENTER" style="-fx-background-color: #1565c0; -fx-padding: 15; -fx-background-radius: 8;">
                            <Label fx:id="totalVentasLabel" text="Total compras: 0"
                                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #c62828; -fx-padding: 15; -fx-background-radius: 8;">
                            <Label fx:id="tasaCancelacionLabel" text="Tasa cancelacion: 0%"
                                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox alignment="CENTER" style="-fx-background-color: #2e7d32; -fx-padding: 15; -fx-background-radius: 8;">
                            <Label fx:id="topEventoLabel" text="Top evento: Sin datos"
                                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        </VBox>
                        <Button text="Actualizar graficas" onAction="#handleActualizarGraficas"
                                style="-fx-background-color: #1565c0; -fx-text-fill: white;"/>
                    </HBox>

                    <!-- Grafica 1: Ventas por periodo -->
                    <Label text="Ventas por periodo"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <LineChart fx:id="ventasPeriodoChart" prefHeight="260" animated="false">
                        <xAxis><CategoryAxis label="Mes"/></xAxis>
                        <yAxis><NumberAxis label="Ventas"/></yAxis>
                    </LineChart>

                    <!-- Grafica 2: Ocupacion por zona -->
                    <Label text="Ocupacion por zona"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <BarChart fx:id="ocupacionZonaChart" prefHeight="260" animated="false">
                        <xAxis><CategoryAxis label="Zona"/></xAxis>
                        <yAxis><NumberAxis label="Asientos vendidos"/></yAxis>
                    </BarChart>

                    <!-- Grafica 3: Ingresos por servicios -->
                    <Label text="Ingresos por servicios adicionales"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <PieChart fx:id="ingresoServiciosChart" prefHeight="280" animated="false"/>

                    <!-- Reportes CSV -->
                    <Label text="Exportar reportes operativos"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="tipoReporteComboBox" prefWidth="260"/>
                        <Button text="Generar CSV" onAction="#handleGenerarReporte"
                                style="-fx-background-color: #00796b; -fx-text-fill: white;"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </Tab>

    </TabPane>
</VBox>
