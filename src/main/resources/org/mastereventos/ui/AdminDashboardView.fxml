<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.mastereventos.controller.AdminDashboardController"
            style="-fx-background-color: #eef2ff;">

    <content>

        <VBox alignment="CENTER"
              spacing="15"
              prefWidth="900"
              style="-fx-background-color: #eef2ff;">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="Panel Administrador"
                   style="-fx-font-size: 30px; -fx-font-weight: bold;"/>

            <!-- EVENTOS -->

            <Label text="Gestión de Eventos"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <VBox spacing="10"
                  alignment="CENTER">

                <TextField fx:id="nombreEventoField"
                           promptText="Nombre del evento"
                           prefWidth="300"/>

                <TextField fx:id="categoriaEventoField"
                           promptText="Categoría"
                           prefWidth="300"/>

                <TextField fx:id="ciudadEventoField"
                           promptText="Ciudad"
                           prefWidth="300"/>

                <TextField fx:id="fechaEventoField"
                           promptText="Fecha"
                           prefWidth="300"/>

                <TextArea fx:id="descripcionEventoArea"
                          promptText="Descripción"
                          prefWidth="300"
                          prefHeight="80"/>

                <Button text="Crear Evento"
                        onAction="#handleCrearEvento"/>

            </VBox>

            <ListView fx:id="eventosListView"
                      prefWidth="700"
                      prefHeight="220"/>

            <HBox spacing="10"
                  alignment="CENTER">

                <Button text="Publicar Evento"
                        onAction="#handlePublicarEvento"/>

                <Button text="Pausar Evento"
                        onAction="#handlePausarEvento"/>

                <Button text="Cancelar Evento"
                        onAction="#handleCancelarEvento"/>

                <Button text="Editar Evento"
                        onAction="#handleEditarEvento"/>

                <Button text="Eliminar Evento"
                        onAction="#handleEliminarEvento"/>

            </HBox>

            <!-- COMPRAS -->

            <Label text="Compras Registradas"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <ListView fx:id="comprasListView"
                      prefWidth="700"
                      prefHeight="220"/>

            <!-- INCIDENCIAS -->

            <Label text="Incidencias"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <ListView fx:id="incidenciasListView"
                      prefWidth="700"
                      prefHeight="180"/>

            <!-- MÉTRICAS -->

            <Label text="Métricas de Ventas"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <PieChart fx:id="ventasChart"
                      prefWidth="600"
                      prefHeight="350"/>

            <Button text="Cerrar Sesión"
                    onAction="#handleCerrarSesion"
                    style="-fx-background-color: #ef4444;
               -fx-text-fill: white;
               -fx-font-weight: bold;"/>

        </VBox>

    </content>
</ScrollPane>

